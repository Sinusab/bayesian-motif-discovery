import sys
sys.path.append('..')
from src.pwm import create_pwm_from_sequences, PositionWeightMatrix

# Our example data
binding_sites = ['TATAAT', 'TATAAT', 'TATAAT', 'TATGAT', 'TAGAAT']

pwm = create_pwm_from_sequences(binding_sites, pseudocount=1.0)

print("Probability matrix:")
