# Test scoring
for seq in ['TATAAT', 'TATAAA', 'GGGGGG']:
    print(f"\n{seq}: score={pwm.score_sequence(seq):.6f}, log_score={pwm.score_log(seq):.4f}")

print(f"\nInformation content per position: {pwm.information_content()}")
